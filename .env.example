# MinIO Configuration
# ==================
# Credenciais do MinIO (object storage S3-compatible)
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123
MINIO_URL=http://localhost:9000

# External APIs Configuration (Em desenvolvimento)
# =================================================
# OMDB API - The Open Movie Database
# Registre em: http://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# TMDB API - The Movie Database
# Registre em: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Kaggle Configuration
# ====================
# Verifique as instruções em README.md para configurar a API do Kaggle
# O arquivo kaggle.json deve estar em ~/.kaggle/

# AWS Configuration (Para produção)
# ==================================
# Descomente e configure se usar AWS S3 em produção
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1

# Application Settings
# ====================
# LOG_LEVEL=INFO
# DEBUG=False
